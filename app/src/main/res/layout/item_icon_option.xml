<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/spacing_s"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp">

        <View
            android:id="@+id/iconBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/ic_circle_entry" />

        <com.mikepenz.iconics.view.IconicsImageView
            android:id="@+id/ivIcon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            app:iiv_color="@color/entry_icon_fg"
            android:contentDescription="@null" />

        <View
            android:id="@+id/selectedRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/icon_option_selected_ring"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvIconLabel"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:textSize="@dimen/text_caption"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="GitHub" />

</LinearLayout>
